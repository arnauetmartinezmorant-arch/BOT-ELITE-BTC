# ── Bot de Telegram (cópialo a .env o configúralo en tu hosting) ──

# 1) Token del bot, te lo da @BotFather al crear el bot
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) Un canal por cada modo. Crea 2 canales en Telegram, añade tu bot como
#    administrador en cada uno, y pon aquí el @usuario del canal (público) o
#    el chat_id numérico (privado, normalmente empieza por -100...).
TELEGRAM_CHAT_CONSERVADOR=@mi_canal_conservador
TELEGRAM_CHAT_PREMIUM=@mi_canal_premium

# 3) Ajustes opcionales
TIMEFRAMES=5m,15m,1h,4h     # temporalidades a vigilar
CHECK_INTERVAL_SEC=60       # cada cuántos segundos escanea el mercado
COOLDOWN_MIN=30             # no repite la misma señal (modo+tf) antes de N minutos

# Pruebas sin enviar nada a Telegram (imprime en consola):
# DRY_RUN=1
